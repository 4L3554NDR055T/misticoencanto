# ===== MÍSTICO ENCANTO — CONFIGURAÇÃO RENDER =====
# Este arquivo é usado quando o projeto está publicado no Render
# Para desenvolvimento local, use .env.local

# ===== PORTA (Render define automaticamente via PORT_ENV) =====
# NÃO altere — Render define esto automaticamente
PORT=3000

# ===== MONGODB ATLAS =====
# CRÍTICO: Cole aqui sua string de conexão do MongoDB Atlas
# Modelo: mongodb+srv://usuario:senha@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
# Obter em: https://www.mongodb.com/cloud/atlas → Connect → Drivers
MONGO_URI=

# ===== AUTENTICAÇÃO ADMIN =====
# Senha para acessar o painel administrativo
# ⚠️ ALTERE ANTES DE PUBLICAR — use algo único e forte!
ADMIN_PASSWORD=

# ===== SEGURANÇA — SALT PARA HASH DE SENHA =====
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Não reutilize o valor de desenvolvimento!
HASH_SALT=

# ===== CORS — ORIGENS PERMITIDAS =====
# Separe múltiplas origens com vírgula
# Exemplo: https://misticoencanto.com,https://www.misticoencanto.com
# ❌ NÃO use * em produção
ALLOWED_ORIGINS=

# ===== SESSÃO =====
# Duração da sessão admin em horas
SESSION_HOURS=8

# ===== RATE LIMITING — PROTEÇÃO CONTRA ATAQUES =====
# Máximo de tentativas de login em RATE_LIMIT_MINUTES
RATE_LIMIT_MAX=10
RATE_LIMIT_MINUTES=15

# ===== NODE ENVIRONMENT =====
# Use sempre "production" em Render
NODE_ENV=production
