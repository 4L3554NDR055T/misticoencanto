# Porta do servidor (o Render define automaticamente)
PORT=3001

# String de conexão do MongoDB Atlas — cole aqui após criar o cluster
MONGO_URI=mongodb+srv://USUARIO:SENHA@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# Senha do painel admin — ALTERE ANTES DE PUBLICAR
ADMIN_PASSWORD=MisticoEncanto@2025

# Salt para hash de senha — mude para algo único seu
HASH_SALT=mistico_encanto_salt_2025

# Origens permitidas (* = qualquer origem, ou coloque sua URL do Render)
ALLOWED_ORIGINS=*

# Duração da sessão em horas (padrão: 8)
SESSION_HOURS=8

# Rate limit login
RATE_LIMIT_MAX=10
RATE_LIMIT_MINUTES=15
